{
  "manifest_version": 3,
  "name": "ChatGPT History Jump",
  "short_name": "History Jump",
  "version": "0.1.0",
  "description": "在 ChatGPT 会话页面右侧生成历史问题目录，支持快速定位和跳转。",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "ChatGPT History Jump"
  }
}